# =============================================================================
# SovereignStack — Environment Configuration
# =============================================================================
# Copy this file to .env and customize for your deployment.
# =============================================================================

# --- Compliance Mode ---
# STRICT = enforce all OASA axioms (default for production)
# DEVELOPMENT = allow non-compliant operations for testing
OASA_ENFORCE_COMPLIANCE=STRICT

# --- Authentication ---
# STRICT = require valid OIDC/JWT bearer token
# DEVELOPMENT = skip auth checks for testing
OASA_ENFORCE_AUTH=STRICT

# --- Policy Engine ---
# STRICT = enforce OPA DLP/RBAC policies
# DEVELOPMENT = skip policy checks
OASA_ENFORCE_POLICY=STRICT

# --- OpenTelemetry ---
OASA_OPENTELEMETRY_ENABLED=true

# --- Identity Provider (Keycloak) ---
OIDC_ISSUER_URL=http://keycloak:8083/realms/sovereign
OIDC_CLIENT_ID=sovereign-gateway
# Keycloak admin credentials (change in production)
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin

# --- Inference Backend ---
# vllm = use vLLM engine (default, production)
# legacy = use mock compute service (for testing only)
INFERENCE_BACKEND=vllm

# --- Internal Service URLs ---
COMPUTE_URL=http://vllm:8000
MEMORY_URL=http://memory:8082

# --- vLLM Configuration ---
# Model name (must be available in /data/ directory)
VLLM_MODEL_NAME=Qwen/Qwen2.5-7B-Instruct
# Max context length in tokens
VLLM_MAX_MODEL_LEN=4096
# GPU memory utilization (0.0 - 1.0)
VLLM_GPU_MEMORY_UTIL=0.90
# Number of GPUs for tensor parallelism
VLLM_GPU_COUNT=1

# --- Local Model Config (legacy backend) ---
LOCAL_MODEL_NAME=sovereign-llama3

# --- SPIFFE/SPIRE Identity ---
SPIFFE_ENABLED=false
SPIFFE_TRUST_DOMAIN=sovereign.stack
SPIRE_SOCKET_PATH=/var/run/spire/agent.sock

# --- Data Directories ---
DATA_DIR=/app/data
