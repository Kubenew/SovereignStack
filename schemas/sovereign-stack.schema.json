{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SovereignStack Node Manifest Schema",
  "type": "object",
  "required": ["version", "metadata", "node_infrastructure"],
  "properties": {
    "version": {
      "type": "string",
      "description": "OASA specification version",
      "pattern": "^\\d{4}\\.\\d+$"
    },
    "metadata": {
      "type": "object",
      "required": ["name", "tier", "compliance_profile"],
      "properties": {
        "name": { "type": "string" },
        "tier": { "type": "string" },
        "compliance_profile": { "type": "string" }
      }
    },
    "node_infrastructure": {
      "type": "object",
      "required": ["engine", "air_gapped_enforcement"],
      "properties": {
        "engine": { "type": "string" },
        "air_gapped_enforcement": { "type": "boolean" },
        "storage": {
          "type": "object",
          "properties": {
            "ephemeral_encrypted": { "type": "boolean" },
            "encryption_algorithm": { "type": "string" },
            "hardware_tpm_binding": { "type": "boolean" }
          }
        },
        "network_isolation": {
          "type": "object",
          "properties": {
            "allow_wan": { "type": "boolean" },
            "dns_mode": { "type": "string" },
            "allowed_internal_cidrs": { "type": "array", "items": { "type": "string" } }
          }
        }
      }
    },
    "data_ingestion": {
      "type": "object",
      "properties": {
        "service_name": { "type": "string" },
        "max_parallel_workers": { "type": "integer" },
        "memory_processing_mode": { "type": "string" },
        "input_formats": { "type": "array", "items": { "type": "string" } }
      }
    },
    "cognitive_memory": {
      "type": "object",
      "properties": {
        "backend": { "type": "string" },
        "vector_dimensions": { "type": "integer" },
        "encryption_at_rest": { "type": "boolean" },
        "context_ttl_seconds": { "type": "integer" }
      }
    },
    "compute_execution": {
      "type": "object",
      "properties": {
        "gateway": { "type": "string" },
        "optimization_engine": { "type": "string" },
        "precision": { "type": "string" },
        "hardware": {
          "type": "object",
          "properties": {
            "accelerator": { "type": "string" },
            "vram_budget_gb": { "type": "number" },
            "allow_cpu_fallback": { "type": "boolean" }
          }
        },
        "runtime_protection": {
          "type": "object",
          "properties": {
            "enforce_compliance_lock": { "type": "boolean" },
            "memory_leak_threshold_mb": { "type": "number" },
            "max_token_context": { "type": "integer" }
          }
        }
      }
    },
    "services": {
      "type": "object",
      "properties": {
        "gateway": { "type": "object" },
        "ingest": { "type": "object" },
        "memory": { "type": "object" },
        "compute": { "type": "object" }
      }
    },
    "models": {
      "type": "object",
      "properties": {
        "allowed": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}
