{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://raw.githubusercontent.com/Kubenew/SovereignStack/main/schemas/certification/oasa-conformance-report.schema.json",
  "title": "OASA Conformance Report Schema",
  "description": "Schema for OASA conformance test suite reports",
  "type": "object",
  "required": ["report_version", "level", "timestamp", "summary", "results"],
  "properties": {
    "report_version": {
      "type": "string",
      "description": "Version of the report format"
    },
    "level": {
      "type": "string",
      "enum": ["L1", "L2", "L3"],
      "description": "Conformance level tested"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of test execution"
    },
    "duration_seconds": {
      "type": "number",
      "description": "Total test duration in seconds"
    },
    "summary": {
      "type": "object",
      "required": ["total", "passed", "failed", "skipped"],
      "properties": {
        "total": { "type": "integer" },
        "passed": { "type": "integer" },
        "failed": { "type": "integer" },
        "skipped": { "type": "integer" },
        "pass_rate": { "type": "number", "minimum": 0, "maximum": 100 }
      }
    },
    "environment": {
      "type": "object",
      "properties": {
        "os": { "type": "string" },
        "python": { "type": "string" },
        "cuda": { "type": "string" },
        "tpm_present": { "type": "boolean" },
        "gpu_model": { "type": "string" },
        "vram_gb": { "type": "number" }
      }
    },
    "results": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "status", "category"],
        "properties": {
          "name": { "type": "string" },
          "status": { "type": "string", "enum": ["pass", "fail", "skip", "error"] },
          "category": {
            "type": "string",
            "enum": ["schema", "compliance-lock", "exfiltration", "ingestion", "hardware", "audit", "performance", "network"]
          },
          "duration_ms": { "type": "number" },
          "message": { "type": "string" }
        }
      }
    },
    "recommendations": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "severity": { "type": "string", "enum": ["critical", "high", "medium", "low", "info"] },
          "message": { "type": "string" },
          "regulation": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": ["GDPR", "EU-AI-Act", "HIPAA", "DORA", "NIS2", "SOX", "CCPA"]
            }
          }
        }
      }
    }
  }
}
